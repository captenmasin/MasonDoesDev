---
// Design 3: Studio Dark — bold dark, orange accent, agency portfolio feel
import Layout from '../layouts/Layout.astro';

const projects = [
    { name: 'Novogamer', url: 'https://novogamer.com', desc: 'Community gaming platform with AI-driven content discovery. Laravel + Vue + Inertia + TS. Queue-based architecture, vector embeddings.', status: 'Live' },
    { name: 'Bookbound', url: 'https://bookbound.app', desc: 'Personal library & book tracking. API cataloguing, reviews, notes, clean UX.', status: 'Live' },
    { name: 'SEO Toolkit', url: 'https://seotoolkit.dev', desc: 'Fast, modular SEO utilities for developers and marketers.', status: 'Live' },
    { name: 'SEO Toolkit 2', url: null, desc: 'Full site monitoring SaaS — uptime, SSL, DNS, broken links. Multi-site dashboard with real-time alerting and team support.', status: 'In Dev' },
    { name: 'Browser.is', url: 'https://browser.is', desc: 'Platform for fast, single-purpose web utility tools.', status: 'Live' },
];
---

<Layout title="Mason Day">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap');
        body { font-family: 'Inter', sans-serif; background: #111111; }
        .serif { font-family: 'Instrument Serif', serif; }
        .arrow { transition: transform 0.2s ease; display: inline-block; }
        .project-row:hover .arrow { transform: translateX(4px); }
    </style>

    <div class="text-white min-h-screen">

        <!-- Nav -->
        <nav class="border-b border-white/10 px-8 py-4 flex items-center justify-between sticky top-0 bg-[#111111]/95 backdrop-blur-sm z-10">
            <span class="text-sm font-semibold tracking-tight">Mason Day</span>
            <div class="flex items-center gap-5">
                <a href="https://github.com/captenmasin" target="_blank" class="text-white/40 hover:text-white text-xs transition-colors">GitHub</a>
                <a href="https://x.com/capten_masin" target="_blank" class="text-white/40 hover:text-white text-xs transition-colors">Twitter</a>
                <a href="mailto:daymason@hotmail.co.uk" class="text-xs bg-[#FF6B00] text-white px-4 py-1.5 rounded-full hover:bg-[#e56000] transition-colors">Get in touch</a>
            </div>
        </nav>

        <div class="max-w-5xl mx-auto px-8">

            <!-- Hero -->
            <section class="py-24 md:py-36 border-b border-white/10">
                <div class="grid md:grid-cols-2 gap-16 items-end">
                    <div>
                        <div class="text-[#FF6B00] text-xs font-semibold uppercase tracking-widest mb-6">Full-Stack Developer · 2016 – Present</div>
                        <h1 class="serif text-6xl md:text-8xl leading-none mb-6">
                            Building<br />things<br /><em>that work.</em>
                        </h1>
                    </div>
                    <div>
                        <p class="text-white/55 text-lg leading-relaxed mb-8">
                            Nearly a decade of shipping real products. I specialise in Laravel, Vue&nbsp;3, and TypeScript — from custom CMS platforms to full SaaS applications.
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {['Laravel', 'Vue 3', 'TypeScript', 'Inertia.js', 'PHP', 'MySQL', 'WordPress', 'TailwindCSS'].map(s => (
                                <span class="text-xs text-white/40 border border-white/10 px-3 py-1.5 rounded-full">{s}</span>
                            ))}
                        </div>
                    </div>
                </div>
            </section>

            <!-- Stats -->
            <section class="py-12 border-b border-white/10 grid grid-cols-3 gap-8">
                <div>
                    <div class="serif text-5xl text-[#FF6B00] mb-1">50+</div>
                    <div class="text-white/40 text-sm">Client projects delivered</div>
                </div>
                <div>
                    <div class="serif text-5xl text-white mb-1">9</div>
                    <div class="text-white/40 text-sm">Years commercial experience</div>
                </div>
                <div>
                    <div class="serif text-5xl text-white mb-1">5</div>
                    <div class="text-white/40 text-sm">Independent products shipped</div>
                </div>
            </section>

            <!-- Projects -->
            <section class="py-16 border-b border-white/10">
                <div class="flex items-baseline justify-between mb-12">
                    <h2 class="serif text-4xl">Projects</h2>
                    <span class="text-white/25 text-xs uppercase tracking-widest">Selected work</span>
                </div>

                {projects.map((p, i) => (
                    <div class="project-row py-8 border-b border-white/5 group">
                        <div class="grid md:grid-cols-[1fr_auto] gap-6 items-start">
                            <div class="flex items-start gap-6">
                                <span class="text-white/15 text-sm w-6 shrink-0 pt-1 font-mono">{String(i + 1).padStart(2, '0')}</span>
                                <div>
                                    <div class="flex items-center gap-3 mb-2">
                                        <h3 class="serif text-2xl group-hover:text-[#FF6B00] transition-colors">{p.name}</h3>
                                        <span class={`text-xs px-2 py-0.5 rounded border ${p.status === 'In Dev' ? 'text-yellow-400 border-yellow-700/40' : 'text-[#FF6B00] border-[#FF6B00]/30'}`}>{p.status}</span>
                                    </div>
                                    <p class="text-white/45 text-sm leading-relaxed">{p.desc}</p>
                                </div>
                            </div>
                            {p.url && (
                                <a href={p.url} target="_blank" class="text-white/25 hover:text-[#FF6B00] text-sm transition-colors shrink-0 mt-1">
                                    Visit <span class="arrow">→</span>
                                </a>
                            )}
                        </div>
                    </div>
                ))}
            </section>

            <!-- Experience + Capabilities -->
            <section class="py-16 border-b border-white/10 grid md:grid-cols-2 gap-16">
                <div>
                    <h2 class="serif text-4xl mb-12">Experience</h2>
                    <div class="space-y-10">
                        <div>
                            <div class="flex justify-between items-start mb-1">
                                <span class="font-medium">Speed.agency</span>
                                <span class="text-white/25 text-xs">2016 – Present</span>
                            </div>
                            <div class="text-[#FF6B00] text-xs mb-3">Web Developer</div>
                            <p class="text-white/45 text-sm leading-relaxed">50+ projects delivered end-to-end. Full ownership of architecture, UI/UX, performance, and deployment. Built modern Laravel + Vue + Inertia.js stacks.</p>
                        </div>
                        <div>
                            <div class="flex justify-between items-start mb-1">
                                <span class="font-medium text-white/40">StyleSeating</span>
                                <span class="text-white/20 text-xs">2015 – 2016</span>
                            </div>
                            <div class="text-white/25 text-xs mb-3">IT Support Apprentice</div>
                            <p class="text-white/25 text-sm">Web, social media, email marketing.</p>
                        </div>
                    </div>
                </div>
                <div>
                    <h2 class="serif text-4xl mb-12">Capabilities</h2>
                    <div class="space-y-5">
                        {[
                            { title: 'Backend Engineering', detail: 'Laravel, PHP, MySQL/PostgreSQL, Redis, queues, Horizon, Octane' },
                            { title: 'Frontend Development', detail: 'Vue 3, TypeScript, Inertia.js, TailwindCSS, component systems' },
                            { title: 'CMS & Content', detail: 'WordPress, custom themes & plugins, ACF, headless CMS' },
                            { title: 'Infrastructure', detail: 'Linux servers, Apache/Nginx, Git, Vite, CI/CD pipelines' },
                        ].map(c => (
                            <div class="flex gap-4">
                                <div class="w-1.5 h-1.5 rounded-full bg-[#FF6B00] mt-2 shrink-0"></div>
                                <div>
                                    <div class="text-sm font-medium mb-0.5">{c.title}</div>
                                    <div class="text-white/35 text-xs leading-relaxed">{c.detail}</div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </section>

            <footer class="py-12 text-center">
                <p class="text-white/15 text-sm">masondoes.dev — Mason Day</p>
            </footer>

        </div>
    </div>
</Layout>
