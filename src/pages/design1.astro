---
// Design 1: Terminal — dark hacker aesthetic, monospace, green accent
import Layout from '../layouts/Layout.astro';

const projects = [
    { name: 'novogamer', url: 'https://novogamer.com', desc: 'Community gaming platform — articles, reviews, guides. Laravel + Inertia + Vue + TS. AI-driven content discovery, vector embeddings.', tag: 'live' },
    { name: 'bookbound', url: 'https://bookbound.app', desc: 'Personal library & book tracking app. Catalogue via APIs, reviews, notes, custom organisation.', tag: 'live' },
    { name: 'seotoolkit', url: 'https://seotoolkit.dev', desc: 'Lightweight, modular SEO utilities for developers and marketers. Fast and practical.', tag: 'live' },
    { name: 'seotoolkit_v2', url: null, desc: 'Full site monitoring & SEO auditing SaaS. Uptime, SSL, broken links, DNS, performance — multi-site dashboard with alerting.', tag: 'wip' },
    { name: 'browser.is', url: 'https://browser.is', desc: 'Web-based platform for small, fast utility tools. Foundation for rapid single-purpose tool deployment.', tag: 'live' },
];
---

<Layout title="Mason Day — Terminal">
    <style>
        * { font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace; }
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap');
        .blink { animation: blink 1s step-end infinite; }
        @keyframes blink { 50% { opacity: 0; } }
        .scanline {
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,65,0.012) 2px, rgba(0,255,65,0.012) 4px);
            pointer-events: none;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #00ff41; border-radius: 3px; }
    </style>

    <div class="bg-[#0d1117] text-[#00ff41] min-h-screen">
        <!-- Scanline overlay -->
        <div class="fixed inset-0 scanline z-50 pointer-events-none opacity-25"></div>

        <div class="max-w-4xl mx-auto px-6 py-16">

            <!-- Header -->
            <header class="mb-16">
                <div class="text-[#4a5568] text-xs mb-4">// masondoes.dev — portfolio</div>
                <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 leading-none tracking-tight">
                    mason<span class="text-[#00ff41]">.</span>day
                </h1>
                <div class="flex items-center gap-2 text-[#00ff41] mb-3">
                    <span class="text-[#4a5568]">$</span>
                    <span>whoami</span>
                    <span class="blink">▌</span>
                </div>
                <div class="text-[#8b949e] text-sm leading-7">
                    <span class="text-[#00ff41]">→</span> Senior Web Developer / Full-Stack Engineer<br />
                    <span class="text-[#00ff41]">→</span> Laravel · Vue 3 · TypeScript · Inertia.js · PHP<br />
                    <span class="text-[#00ff41]">→</span> ~9 years commercial experience · 50+ projects shipped
                </div>
                <div class="flex gap-6 mt-6 text-xs">
                    <a href="mailto:daymason@hotmail.co.uk" class="text-[#4a5568] hover:text-[#00ff41] transition-colors">daymason@hotmail.co.uk</a>
                    <a href="https://github.com/captenmasin" target="_blank" class="text-[#4a5568] hover:text-[#00ff41] transition-colors">github/captenmasin</a>
                    <a href="https://x.com/capten_masin" target="_blank" class="text-[#4a5568] hover:text-[#00ff41] transition-colors">x/capten_masin</a>
                </div>
            </header>

            <!-- Skills -->
            <section class="mb-16">
                <div class="text-[#4a5568] text-xs mb-5 uppercase tracking-widest">// core_skills</div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {[
                        { label: 'BACKEND', items: ['Laravel — API, queues, Horizon, Octane', 'PHP (modern OOP, performance-focused)', 'MySQL / PostgreSQL + pgvector', 'Redis, queue-based architectures'] },
                        { label: 'FRONTEND', items: ['Vue 3 + TypeScript', 'Inertia.js', 'TailwindCSS — component-driven', 'Vite, modern build tooling'] },
                        { label: 'CMS & PLATFORMS', items: ['WordPress — themes, plugins, ACF', 'Custom plugin development', 'Headless and hybrid CMS'] },
                        { label: 'DEVOPS & TOOLS', items: ['Linux — Ubuntu, Apache / Nginx', 'Git, CI/CD workflows', 'Real-time broadcasting', 'Vector embeddings, semantic search'] },
                    ].map(group => (
                        <div class="border border-[#1e2a1e] bg-[#0a1a0a] p-5 rounded">
                            <div class="text-[#00ff41] text-xs mb-3 opacity-60">{group.label}</div>
                            <ul class="space-y-1.5 text-[#8b949e] text-sm">
                                {group.items.map(item => (
                                    <li><span class="text-[#00ff41]">+</span> {item}</li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Projects -->
            <section class="mb-16">
                <div class="text-[#4a5568] text-xs mb-5 uppercase tracking-widest">// projects/</div>
                <div class="space-y-3">
                    {projects.map(p => (
                        <div class="border border-[#1e2a1e] bg-[#0a1a0a] p-5 rounded hover:border-[#00ff41]/25 transition-colors">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-3 mb-2">
                                        <span class="text-white font-bold">{p.name}/</span>
                                        {p.tag === 'wip'
                                            ? <span class="text-xs bg-yellow-900/40 text-yellow-400 border border-yellow-700/40 px-2 py-0.5 rounded">WIP</span>
                                            : <span class="text-xs bg-green-900/40 text-[#00ff41] border border-[#00ff41]/25 px-2 py-0.5 rounded">LIVE</span>
                                        }
                                    </div>
                                    <p class="text-[#8b949e] text-sm">{p.desc}</p>
                                </div>
                                {p.url && (
                                    <a href={p.url} target="_blank" class="text-[#4a5568] hover:text-[#00ff41] text-xs shrink-0 mt-1 transition-colors">→ visit</a>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Experience -->
            <section class="mb-16">
                <div class="text-[#4a5568] text-xs mb-5 uppercase tracking-widest">// experience</div>
                <div class="space-y-6">
                    <div class="border-l-2 border-[#00ff41]/30 pl-6">
                        <div class="text-white font-bold">Speed.agency</div>
                        <div class="text-[#4a5568] text-xs mb-2">Web Developer — 2016 → Present</div>
                        <p class="text-[#8b949e] text-sm leading-relaxed">Delivered and maintained 50+ WordPress and Laravel projects. Led full-stack development from architecture to deployment. Built modern Laravel + Vue + Inertia.js applications, managed Linux servers, and led ongoing technical support.</p>
                    </div>
                    <div class="border-l-2 border-[#1e2a1e] pl-6">
                        <div class="text-[#6b7280] font-bold">StyleSeating</div>
                        <div class="text-[#4a5568] text-xs mb-2">IT Support Apprentice — 2015 → 2016</div>
                        <p class="text-[#4a5568] text-sm">Website maintenance, social media management, email marketing.</p>
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer class="border-t border-[#1e2a1e] pt-8 text-[#4a5568] text-xs">
                <span class="text-[#00ff41]">$</span> masondoes.dev — Mason Day
            </footer>

        </div>
    </div>
</Layout>
