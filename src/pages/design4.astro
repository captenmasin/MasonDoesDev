---
// Design 4: Glassmorphism — dark navy/purple gradient, frosted glass cards
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mason Day">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background: #060a14;
            background-image:
                radial-gradient(ellipse 80% 50% at 20% -10%, rgba(99,57,255,0.35) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 100%, rgba(30,120,255,0.2) 0%, transparent 60%);
            min-height: 100vh;
        }
        .serif { font-family: 'Instrument Serif', serif; }
        .glass {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .glass-hover { transition: background 0.2s ease, border-color 0.2s ease; }
        .glass-hover:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.14); }
        .glow { text-shadow: 0 0 60px rgba(99,57,255,0.5); }
        .pulse { animation: pulse 2s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    </style>

    <div class="text-white min-h-screen overflow-x-hidden">
        <div class="max-w-5xl mx-auto px-6 py-16 relative">

            <!-- Header -->
            <header class="text-center py-20 md:py-28">
                <div class="inline-flex items-center gap-2 glass rounded-full px-4 py-1.5 text-xs text-white/40 mb-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-400 inline-block pulse"></span>
                    Available for new projects
                </div>
                <h1 class="serif text-7xl md:text-[100px] leading-none glow mb-6">Mason Day</h1>
                <p class="text-white/45 text-lg max-w-xl mx-auto leading-relaxed">
                    Senior full-stack developer crafting scalable web applications with Laravel, Vue&nbsp;3, and TypeScript. ~9 years of commercial experience, 50+ projects shipped.
                </p>
                <div class="flex items-center justify-center gap-4 mt-10">
                    <a href="mailto:daymason@hotmail.co.uk" class="glass glass-hover px-6 py-2.5 rounded-full text-sm text-white/70 hover:text-white transition-colors">Contact me</a>
                    <a href="https://github.com/captenmasin" target="_blank" class="glass glass-hover px-6 py-2.5 rounded-full text-sm text-white/70 hover:text-white transition-colors">GitHub →</a>
                </div>
            </header>

            <!-- Skills -->
            <div class="glass rounded-2xl p-8 mb-6">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    {[
                        { label: 'Backend', items: ['Laravel', 'PHP', 'MySQL', 'PostgreSQL', 'Redis'] },
                        { label: 'Frontend', items: ['Vue 3', 'TypeScript', 'Inertia.js', 'TailwindCSS'] },
                        { label: 'CMS', items: ['WordPress', 'Custom plugins', 'ACF', 'Headless'] },
                        { label: 'DevOps', items: ['Linux', 'Nginx', 'Git', 'CI/CD', 'Vite'] },
                    ].map(g => (
                        <div>
                            <div class="text-xs text-white/25 uppercase tracking-widest mb-3">{g.label}</div>
                            <ul class="space-y-1.5">
                                {g.items.map(item => <li class="text-sm text-white/55">{item}</li>)}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Projects -->
            <section class="mb-6">
                <h2 class="serif text-3xl mb-5 px-1">Projects</h2>
                <div class="grid md:grid-cols-2 gap-4">
                    {[
                        { name: 'Novogamer', url: 'https://novogamer.com', desc: 'Community gaming platform with AI-driven content discovery. Laravel, Inertia.js, Vue, TypeScript — queues, caching, vector embeddings.', wip: false },
                        { name: 'Bookbound', url: 'https://bookbound.app', desc: 'Personal library & book tracking. Catalogue books via APIs, reviews, notes. Clean UX, extensible architecture.', wip: false },
                        { name: 'SEO Toolkit', url: 'https://seotoolkit.dev', desc: 'Modular SEO utilities for devs & marketers. Fast, practical, performance-focused.', wip: false },
                        { name: 'SEO Toolkit 2', url: null, desc: 'Full site monitoring SaaS — uptime, SSL, DNS, broken links across multiple sites. Real-time dashboard, alerting, team support.', wip: true },
                        { name: 'Browser.is', url: 'https://browser.is', desc: 'Platform for rapid development of small, single-purpose web utility tools.', wip: false },
                    ].map(p => (
                        <div class="glass glass-hover rounded-2xl p-6">
                            <div class="flex items-start justify-between mb-4">
                                <div class="flex items-center gap-3">
                                    <h3 class="serif text-xl">{p.name}</h3>
                                    {p.wip
                                        ? <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">In dev</span>
                                        : <span class="text-xs px-2 py-0.5 rounded-full bg-violet-500/15 text-violet-300 border border-violet-500/25">Live</span>
                                    }
                                </div>
                                {p.url && (
                                    <a href={p.url} target="_blank" class="text-white/20 hover:text-white/60 transition-colors text-sm ml-4 shrink-0">↗</a>
                                )}
                            </div>
                            <p class="text-white/45 text-sm leading-relaxed">{p.desc}</p>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Experience -->
            <section class="mb-6">
                <h2 class="serif text-3xl mb-5 px-1">Experience</h2>
                <div class="glass rounded-2xl divide-y divide-white/5">
                    <div class="p-6">
                        <div class="flex items-start justify-between mb-1">
                            <span class="font-medium">Speed.agency</span>
                            <span class="text-white/25 text-xs">2016 – Present</span>
                        </div>
                        <div class="text-violet-400 text-xs mb-3">Web Developer</div>
                        <p class="text-white/45 text-sm leading-relaxed">Delivered and maintained 50+ client projects across WordPress and Laravel. Full ownership from architecture to deployment. Built modern Laravel + Vue + Inertia.js stacks and managed ongoing support.</p>
                    </div>
                    <div class="p-6">
                        <div class="flex items-start justify-between mb-1">
                            <span class="text-white/40 font-medium">StyleSeating</span>
                            <span class="text-white/20 text-xs">2015 – 2016</span>
                        </div>
                        <div class="text-white/25 text-xs mb-3">IT Support Apprentice</div>
                        <p class="text-white/25 text-sm">Website maintenance, social media, email marketing.</p>
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer class="text-center py-12">
                <div class="glass inline-flex items-center gap-5 rounded-full px-8 py-3">
                    <a href="mailto:daymason@hotmail.co.uk" class="text-white/35 hover:text-white text-xs transition-colors">daymason@hotmail.co.uk</a>
                    <span class="text-white/10">|</span>
                    <a href="https://x.com/capten_masin" target="_blank" class="text-white/35 hover:text-white text-xs transition-colors">@capten_masin</a>
                    <span class="text-white/10">|</span>
                    <a href="https://github.com/captenmasin" target="_blank" class="text-white/35 hover:text-white text-xs transition-colors">github/captenmasin</a>
                </div>
            </footer>

        </div>
    </div>
</Layout>
