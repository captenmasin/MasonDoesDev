---
import Layout from '../layouts/Layout.astro';

import { Image } from 'astro:assets';
import MasonImage from '../assets/mason.png'
import MasonWaveImage from '../assets/mason-wave.png'
import {getCollection, render} from "astro:content";

const skillGroups = [
    { label: 'Backend', items: ['Laravel', 'PHP (modern OOP)', 'MySQL / PostgreSQL', 'Redis, queues, Horizon'] },
    { label: 'Frontend', items: ['Vue 3 + TypeScript', 'Inertia.js', 'TailwindCSS', 'Component-driven UI'] },
    { label: 'CMS', items: ['WordPress', 'Custom themes & plugins', 'ACF', 'Headless CMS'] },
    { label: 'Infrastructure', items: ['Linux (Ubuntu)', 'Apache / Nginx', 'Git, Vite, CI/CD', 'Server management'] },
];

const projectEntries = (await getCollection('projects'))
    .sort((a, b) => a.data.order - b.data.order);
const projects = await Promise.all(
    projectEntries.map(async (entry) => ({
        ...entry,
        Content: (await render(entry)).Content,
    }))
);

const tools = [
    { name: 'PHPStorm', url: 'https://www.jetbrains.com/phpstorm/', desc: 'Primary IDE for day-to-day development, debugging, and larger codebase work.' },
    { name: 'Zed', url: 'https://zed.dev/', desc: 'Lightweight editor for quick changes, notes, and smaller edits without full IDE overhead.' },
    { name: 'TablePlus', url: 'https://tableplus.com/', desc: 'Database client for inspecting schemas, running queries, and managing local and remote databases.' },
    { name: 'Laravel Herd', url: 'https://herd.laravel.com/', desc: 'Local PHP development environment for running Laravel projects quickly and consistently.' },
    { name: 'Warp + Oh My Zsh', url: 'https://www.warp.dev/', desc: 'Terminal setup for everyday command line work, with a shell environment tuned for speed and convenience.' },
    { name: 'Ploi', url: 'https://ploi.io/', desc: 'Server provisioning and deployment platform for managing production infrastructure.' },
    { name: 'Hetzner', url: 'https://www.hetzner.com/', desc: 'Preferred hosting provider for the servers I deploy and manage.' },
    { name: 'OpenAI Codex', url: 'https://openai.com/codex/', desc: 'Used for AI-assisted development, refactoring, debugging, and accelerating delivery.' },
    { name: 'GitHub', url: 'https://github.com/', desc: 'Version control, collaboration, and the main home for repositories and code review.' },
    { name: 'Cloudflare', url: 'https://www.cloudflare.com/', desc: 'DNS, domain management, and edge-level tooling for performance and protection.' },
];
---

<Layout title="Mason Day">
    <div class="bg-canvas text-ink min-h-screen">
        <div class="max-w-2xl mx-auto px-8 py-20 md:py-32">
            <header class="mb-10 md:mb-20">
                <div class:list={'flex items-center md:items-start mb-6 gap-4 md:gap-8 md:flex-col'}>
                <div class="group shrink-0 relative size-12 md:size-22">
                    <Image
                        src={MasonImage}
                        alt="Mason Day"
                        width="176"
                        height="176"
                        loading={'eager'}
                        class="absolute inset-0 w-full h-full rounded-full object-cover grayscale group-hover:opacity-0"
                    />
                    <Image
                        src={MasonWaveImage}
                        alt="Mason Day waving"
                        width="176"
                        height="176"
                        loading={'eager'}
                        class="absolute inset-0 w-full h-full rounded-full object-cover opacity-0 group-hover:opacity-100"
                    />
                </div>
                <h1 class="font-serif text-3xl md:text-8xl leading-none tracking-tight">Mason Day</h1>
                </div>
                <p class="text-muted text-lg leading-relaxed">
                    Senior full-stack developer with nearly a decade of commercial experience.
                </p>
                <div class="flex flex-wrap gap-x-6 gap-y-2 mt-8">
                    <a href="https://github.com/captenmasin" target="_blank" class="text-sm text-faint link-line">GitHub</a>
                    <a href="https://x.com/capten_masin" target="_blank" class="text-sm text-faint link-line">Twitter</a>
                    <a href="https://www.linkedin.com/in/masonday98/" target="_blank" class="text-sm text-faint link-line">LinkedIn</a>
                    <a href="mailto:mason@spacemancodes.com" class="text-sm text-faint link-line">mason@spacemancodes.com</a>
                </div>
            </header>

            <hr class="border-rule mb-10 md:mb-20" />

            <section class="mb-10 md:mb-20">
                <h2 class="font-serif text-3xl mb-12">Projects</h2>
                <div class="space-y-12">
                    {projects.map(project => (
                        <div>
                            <div class="flex items-baseline gap-4 mb-2">
                                <span class:list={[
                                    'font-serif text-xl',
                                    project.data.links.length ? '' : 'text-placeholder',
                                ]}>
                                    {project.data.name}
                                </span>
                                <span class="text-xs text-ghost uppercase tracking-widest">{project.data.status}</span>
                            </div>
                            <div class="text-muted text-sm leading-relaxed"><project.Content /></div>
                            {project.data.links.length > 0 && (
                                    <div class="flex flex-wrap gap-x-4 gap-y-2 mt-2 text-xs">
                                        {project.data.links.map((link) => (
                                                <a href={link.url} target="_blank" class="bg-black/5 hover:bg-black/10 dark:hover:bg-white/10 dark:bg-white/5 text-black/40 hover:text-black dark:hover:text-white dark:text-white/40 rounded-full flex items-center gap-2 font-normal px-2 py-0.5">
                                                    {link.label === 'Web' && (
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                                                    )}
                                                    {link.label === 'Android' && (
                                                            <svg class="size-4" viewBox="0 0 246 138" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M182.8 41.5149L203.183 6.20658C204.333 4.22704 203.637 1.71301 201.685 0.562759C199.732 -0.587497 197.191 0.0813048 196.068 2.0605L175.418 37.8234C159.663 30.6281 141.929 26.6157 122.857 26.6157C103.785 26.6157 86.0504 30.6281 70.2954 37.8234L49.6452 2.06085C49.374 1.59083 49.0126 1.17905 48.5818 0.849175C48.151 0.519296 47.6591 0.277824 47.1347 0.13864C46.6102 -0.000543401 46.0634 -0.0346945 45.5256 0.0381503C44.9879 0.110995 44.4699 0.289399 44.0014 0.563107C43.5313 0.83425 43.1195 1.19563 42.7896 1.62647C42.4597 2.05731 42.2182 2.54912 42.079 3.07361C41.9398 3.59809 41.9057 4.14492 41.9786 4.68265C42.0514 5.22038 42.2299 5.7384 42.5037 6.20693L62.8859 41.5153C27.7384 60.5603 3.93222 96.1359 0 137.784H245.713C241.781 96.1359 217.975 60.5599 182.8 41.5149ZM66.4438 103.277C60.7466 103.277 56.1455 98.6499 56.1455 92.9792C56.1455 87.282 60.7731 82.681 66.4438 82.681C72.141 82.681 76.742 87.3085 76.742 92.9792C76.7699 98.6499 72.1413 103.277 66.4438 103.277ZM179.243 103.277C173.546 103.277 168.945 98.6499 168.945 92.9792C168.945 87.282 173.572 82.681 179.243 82.681C184.94 82.681 189.541 87.3085 189.541 92.9792C189.569 98.6499 184.94 103.277 179.243 103.277Z" fill="currentColor"/></svg>
                                                    )}
                                                    {link.label}
                                                </a>
                                        ))}
                                    </div>
                            )}
                        </div>
                    ))}
                </div>
            </section>

            <hr class="border-rule mb-10 md:mb-20" />

            <section class="mb-10 md:mb-20">
                <h2 class="font-serif text-3xl mb-12">Skills</h2>
                <div class="grid grid-cols-2 gap-x-12 gap-y-10">
                    {skillGroups.map(group => (
                        <div>
                            <div class="text-xs text-ghost uppercase tracking-widest mb-4">{group.label}</div>
                            <ul class="space-y-1.5 text-sm text-subtle">
                                {group.items.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    ))}
                </div>
            </section>

            <hr class="border-rule mb-10 md:mb-20" />

            <section class="mb-10 md:mb-20">
                <h2 class="font-serif text-3xl mb-12">My Tools</h2>
                <ul class="grid grid-cols-2 gap-x-8 gap-y-4">
                    {tools.map(tool => (
                        <li>
                            <a href={tool.url} target="_blank" class="font-serif text-base link-line">{tool.name}</a>
                            <p class="text-muted text-xs leading-relaxed mt-1">{tool.desc}</p>
                        </li>
                    ))}
                </ul>
            </section>

            <footer class="text-center">
                <p class="font-serif italic text-ghost text-lg">masondoes.dev</p>
            </footer>

        </div>
    </div>
</Layout>
