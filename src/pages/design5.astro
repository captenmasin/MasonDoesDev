---
// Design 5: Brutalist — thick borders, yellow accent, newspaper grid, high contrast
import Layout from '../layouts/Layout.astro';

const projects = [
    { name: 'Novogamer', url: 'https://novogamer.com', desc: 'Community gaming platform — articles, reviews, guides. AI-driven content discovery, vector embeddings.', stack: 'Laravel · Vue · Inertia · TS', wip: false },
    { name: 'Bookbound', url: 'https://bookbound.app', desc: 'Personal library & book tracking. API cataloguing, reviews, notes, custom organisation.', stack: 'Laravel · Vue · Inertia', wip: false },
    { name: 'SEO Toolkit', url: 'https://seotoolkit.dev', desc: 'Lightweight, modular SEO utilities for developers and marketers. Fast, practical, performance-focused.', stack: 'PHP · Vue · TailwindCSS', wip: false },
    { name: 'SEO Toolkit 2', url: null, desc: 'Site monitoring SaaS — uptime, SSL, DNS, broken links. Multi-site dashboard with real-time alerting and team support.', stack: 'Laravel · Vue · Inertia · Redis', wip: true },
    { name: 'Browser.is', url: 'https://browser.is', desc: 'Platform for fast, single-purpose web utility tools. Rapid development and deployment foundation.', stack: 'Laravel · Vue', wip: false },
];
---

<Layout title="Mason Day">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background: #f5f5f0; color: #111; }
        .serif { font-family: 'Instrument Serif', serif; }
        .b3 { border: 3px solid #111; }
        .bb3 { border-bottom: 3px solid #111; }
        .bt3 { border-top: 3px solid #111; }
        .br3 { border-right: 3px solid #111; }
    </style>

    <div class="min-h-screen">

        <!-- Top bar -->
        <div class="bb3 px-6 py-3 flex items-center justify-between bg-[#111] text-white">
            <span class="font-black text-sm uppercase tracking-widest">Mason Day — masondoes.dev</span>
            <div class="hidden md:flex gap-6">
                <a href="mailto:daymason@hotmail.co.uk" class="text-white/50 hover:text-white text-xs transition-colors">Email</a>
                <a href="https://github.com/captenmasin" target="_blank" class="text-white/50 hover:text-white text-xs transition-colors">GitHub</a>
                <a href="https://x.com/capten_masin" target="_blank" class="text-white/50 hover:text-white text-xs transition-colors">Twitter</a>
            </div>
        </div>

        <!-- Hero -->
        <section class="bb3">
            <div class="max-w-6xl mx-auto px-6">
                <div class="grid md:grid-cols-[1fr_280px]">
                    <div class="py-16 md:py-24 md:br3">
                        <div class="inline-block bg-[#FFE000] px-3 py-1 text-xs font-black uppercase tracking-widest mb-6">Senior Web Developer</div>
                        <h1 class="serif text-6xl md:text-[88px] leading-none mb-8">
                            Full-stack<br />
                            <em>engineer</em><br />
                            & builder.
                        </h1>
                        <p class="text-[#444] text-lg leading-relaxed max-w-lg">
                            Nearly a decade building products people use. Specialising in Laravel, Vue&nbsp;3, and TypeScript — 50+ client projects delivered, multiple SaaS platforms shipped.
                        </p>
                    </div>
                    <div class="hidden md:flex flex-col justify-between py-12 pl-8">
                        <div>
                            <div class="text-xs font-black uppercase tracking-widest text-[#999] mb-4">Core Stack</div>
                            <ul class="space-y-0">
                                {['Laravel', 'Vue 3', 'TypeScript', 'Inertia.js', 'PHP', 'MySQL', 'WordPress', 'TailwindCSS', 'Redis', 'Linux'].map(s => (
                                    <li class="text-sm font-bold border-b border-[#ddd] py-2 flex items-center justify-between">
                                        {s}
                                        <span class="bg-[#FFE000] w-1.5 h-1.5 rounded-full inline-block"></span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                        <div class="text-xs text-[#999] font-mono mt-4">2016 → Present</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Projects -->
        <section class="bb3">
            <div class="max-w-6xl mx-auto px-6">
                <div class="py-4 bb3 flex items-baseline justify-between">
                    <h2 class="font-black text-xs uppercase tracking-[0.2em]">Projects</h2>
                    <span class="text-xs text-[#999]">5 total</span>
                </div>

                {projects.map((p, i) => (
                    <div class={`py-8 ${i < projects.length - 1 ? 'border-b border-[#e0e0dc]' : ''} hover:bg-[#FFE000]/30 transition-colors px-2 -mx-2 rounded`}>
                        <div class="grid md:grid-cols-[64px_1fr_auto] gap-4 items-start">
                            <span class="font-black text-3xl text-[#ddd] leading-none">{String(i+1).padStart(2, '0')}</span>
                            <div>
                                <div class="flex items-center gap-3 mb-2">
                                    <h3 class="font-black text-xl">{p.name}</h3>
                                    {p.wip
                                        ? <span class="text-xs font-black uppercase bg-[#111] text-white px-2 py-0.5">WIP</span>
                                        : <span class="text-xs font-black uppercase bg-[#FFE000] text-[#111] px-2 py-0.5">Live</span>
                                    }
                                </div>
                                <p class="text-[#555] text-sm leading-relaxed mb-2">{p.desc}</p>
                                <span class="text-xs text-[#999] font-mono">{p.stack}</span>
                            </div>
                            {p.url && (
                                <a href={p.url} target="_blank" class="b3 text-sm font-black px-4 py-2 hover:bg-[#FFE000] transition-colors whitespace-nowrap shrink-0">
                                    Visit →
                                </a>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Experience + Skills -->
        <section class="bb3">
            <div class="max-w-6xl mx-auto px-6">
                <div class="grid md:grid-cols-2">
                    <div class="py-12 md:pr-12 md:br3">
                        <div class="text-xs font-black uppercase tracking-[0.2em] mb-8 pb-4 bb3">Experience</div>
                        <div class="space-y-10">
                            <div>
                                <div class="flex items-start justify-between mb-1">
                                    <span class="font-black text-lg">Speed.agency</span>
                                    <span class="bg-[#FFE000] text-xs font-bold px-2 py-1">2016 – Now</span>
                                </div>
                                <div class="text-sm font-bold text-[#555] mb-3">Web Developer</div>
                                <p class="text-sm text-[#555] leading-relaxed">Delivered and maintained 50+ WordPress and Laravel client projects. Full-stack ownership — architecture, UI/UX, performance, deployment, and ongoing support.</p>
                            </div>
                            <div>
                                <div class="flex items-start justify-between mb-1">
                                    <span class="font-bold text-[#999]">StyleSeating</span>
                                    <span class="text-xs text-[#999] font-mono">2015–2016</span>
                                </div>
                                <div class="text-sm text-[#bbb] mb-2">IT Support Apprentice</div>
                                <p class="text-sm text-[#ccc]">Website, social media, email marketing.</p>
                            </div>
                        </div>
                    </div>
                    <div class="py-12 md:pl-12">
                        <div class="text-xs font-black uppercase tracking-[0.2em] mb-8 pb-4 bb3">Capabilities</div>
                        <div class="grid grid-cols-2 gap-8">
                            {[
                                { label: 'Backend', items: ['Laravel', 'PHP', 'MySQL', 'PostgreSQL', 'Redis', 'Horizon'] },
                                { label: 'Frontend', items: ['Vue 3', 'TypeScript', 'Inertia.js', 'TailwindCSS'] },
                                { label: 'CMS', items: ['WordPress', 'Custom themes', 'Plugins', 'ACF', 'Headless'] },
                                { label: 'DevOps', items: ['Linux', 'Nginx', 'Apache', 'Git', 'Vite', 'CI/CD'] },
                            ].map(c => (
                                <div>
                                    <div class="text-xs font-black uppercase tracking-wider mb-3">{c.label}</div>
                                    <ul class="space-y-1">
                                        {c.items.map(item => <li class="text-sm text-[#555]">— {item}</li>)}
                                    </ul>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="bg-[#111] text-white px-6 py-8">
            <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div>
                    <div class="font-black text-lg mb-0.5">Mason Day</div>
                    <div class="text-white/35 text-xs">Senior Web Developer · Full-Stack Engineer</div>
                </div>
                <div class="flex gap-6">
                    <a href="mailto:daymason@hotmail.co.uk" class="text-white/40 hover:text-white transition-colors text-sm">daymason@hotmail.co.uk</a>
                    <a href="https://github.com/captenmasin" target="_blank" class="text-white/40 hover:text-white transition-colors text-sm">GitHub</a>
                    <a href="https://x.com/capten_masin" target="_blank" class="text-white/40 hover:text-white transition-colors text-sm">Twitter</a>
                </div>
            </div>
        </footer>

    </div>
</Layout>
