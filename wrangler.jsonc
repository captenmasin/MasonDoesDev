{
  "compatibility_date": "2026-04-19",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "name": "masondoesdev",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "masondoes.dev",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
